# Secrets for the Edge Functions. Set these in Supabase with:
#   supabase secrets set --env-file .env
#
# (Do NOT commit your real .env — only this .example file.)
#
# SUPABASE_URL, SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY are injected
# automatically into deployed Edge Functions, so you do NOT set them here.

# Stripe test-mode secret key (starts with sk_test_)
STRIPE_SECRET_KEY=sk_test_xxx

# Signing secret of the Stripe webhook endpoint (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_xxx
